import kotlin.collections.List;
import kotlin.Boolean;
import kotlin.String;

CREATE TABLE NewestPosts(
  id INTEGER PRIMARY KEY AUTOINCREMENT,
  shortId TEXT NOT NULL,
  shortIdUrl TEXT NOT NULL,
  createdAt TEXT NOT NULL,
  title TEXT NOT NULL,
  url TEXT NOT NULL,
  score INTEGER NOT NULL,
  flags INTEGER NOT NULL,
  commentCount INTEGER NOT NULL,
  description TEXT,
  descriptionPlain TEXT,
  commentsUrl TEXT NOT NULL,
  submitterUsername TEXT NOT NULL,
  submitterCreatedAt TEXT NOT NULL,
  submitterIsAdmin INTEGER AS Boolean NOT NULL,
  submitterAbout TEXT,
  submitterIsModerator INTEGER AS Boolean NOT NULL,
  submitterKarma INTEGER NOT NULL,
  submitterAvatarUrl TEXT,
  submitterInvitedByUser TEXT,
  submitterGithubUsername TEXT,
  userIsAuthor INTEGER AS Boolean NOT NULL,
  tags TEXT AS List<String> NOT NULL
);

addCachedPost:
INSERT OR REPLACE
INTO NewestPosts
VALUES ?;

getCachedPosts:
SELECT *
FROM NewestPosts
ORDER BY datetime(createdAt)
LIMIT :limit
OFFSET :offset;
